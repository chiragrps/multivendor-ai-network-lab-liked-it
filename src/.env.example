# ── DCN Network Tool — Environment Variables ──────────────────────────────────
# Copy this file to .env and adjust values for your environment.

# SSH access to network devices
DCN_SSH_KEY=/data/ssh/netlab_admin
DCN_SSH_USER=netadmin
DCN_SSH_TIMEOUT=30

# Device inventory CSV files
DCN_SECURECRT_CSV=/data/inventory/securecrt_sessions.csv
DCN_NETBOX_CSV=/data/inventory/netbox_ip_addresses.csv

# Config baselines for drift detection
DCN_EOS_CONFIG_DIR=/data/configs/eos
DCN_JUNOS_CONFIG_DIR=/data/configs/junos

# Server
DCN_PORT=5757
DCN_WORKERS=3
DCN_THREADS=4
DCN_LOG_LEVEL=info

# LibreNMS Integration (3 regions)
LIBRENMS_EMEA_URL=https://librenms.emea.example.com
LIBRENMS_EMEA_TOKEN=your-emea-token
LIBRENMS_AMER_URL=https://librenms.amer.example.com
LIBRENMS_AMER_TOKEN=your-amer-token
LIBRENMS_APAC_URL=https://librenms.apac.example.com
LIBRENMS_APAC_TOKEN=your-apac-token
LIBRENMS_ZTASID=your-ztasid-cookie

# NetPortal Capacity API
NETPORTAL_URL=https://netportal.lab.local

# Docker Model Runner (Local LLM — OpenAI-compatible API)
# Adds AI-generated executive narratives to Deep Analysis, Log Intelligence,
# Security Audit, and ISP Links reports. COMPLETELY OPTIONAL — all reports
# work identically without it (rule-based analysis, same scores/findings).
#
# To DISABLE LLM: set LLM_ENABLED=false (or just don't install Docker Model Runner)
# To ENABLE: docker model pull ai/qwen3 (requires Docker Desktop with AI features)
MODEL_RUNNER_URL=http://localhost:12434
LLM_MODEL=ai/qwen3:latest
LLM_ENABLED=true
LLM_TIMEOUT=60

# Junos MCP Server (Read-Only sidecar)
# Provides read-only Junos CLI access via MCP protocol.
# Auto-generates devices.json from DCN inventory (Junos devices only).
# To DISABLE: set JMCP_ENABLED=false
JMCP_URL=http://localhost:30030
JMCP_ENABLED=true

# Docker volume host paths (used by docker-compose)
DCN_SSH_KEY_HOST=./data/ssh
DCN_INVENTORY_HOST=./data/inventory
DCN_CONFIGS_HOST=./data/configs
DCN_PUBLIC_PORT=80
